{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev-debug",
      "inherits": "base",
      "displayName": "Development Debug",
      "description": "Build for daily development with debug info",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-release",
      "inherits": "base",
      "displayName": "Development Release",
      "description": "Build for testing release behavior",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "ci-debug",
      "inherits": "base",
      "displayName": "CI Debug",
      "description": "Build for continuous integration",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tests-debug",
      "inherits": "base",
      "displayName": "Tests Debug",
      "description": "Build and run tests explicitly",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release"
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci-debug"
    },
    {
      "name": "tests-debug",
      "configurePreset": "tests-debug"
    }
  ],
  "testPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-debug",
      "configurePreset": "tests-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
